---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localePath } from '../../utils/url';
import { getLocaleFromUrl, t, SUPPORTED_LOCALES, DEFAULT_LOCALE, type Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l.code !== DEFAULT_LOCALE)
    .map((l) => ({ params: { lang: l.code } }));
}

const locale = getLocaleFromUrl(Astro.url) as Locale;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Merrily Plan',
  description: 'Get in touch with the Merrily Plan team for support, feedback, or partnership inquiries.',
  url: 'https://merrilyplan.com/contact',
};
---

<BaseLayout
  title={t(locale, 'contact.meta.title')}
  description={t(locale, 'contact.meta.description')}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-primary-50 via-white to-accent-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="section-heading mb-4">
        {t(locale, 'contact.hero.heading')}
        <span class="gradient-text">{t(locale, 'contact.hero.headingHighlight')}</span>
      </h1>
      <p class="section-subheading">
        {t(locale, 'contact.hero.subheading')}
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-12 md:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">
            <h2 class="text-2xl font-display font-bold text-gray-900 mb-6">{t(locale, 'contact.form.title')}</h2>

            <form
              id="contact-form"
              action="https://formspree.io/f/xwpkjqvr"
              method="POST"
              class="space-y-6"
              data-sending={t(locale, 'contact.form.sending')}
              data-submit={t(locale, 'contact.form.submit')}
              data-error-alert={t(locale, 'contact.form.errorAlert')}
            >
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'contact.form.nameLabel')}</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 rounded-xl border border-gray-300 text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                    placeholder={t(locale, 'contact.form.namePlaceholder')}
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'contact.form.emailLabel')}</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 rounded-xl border border-gray-300 text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                    placeholder={t(locale, 'contact.form.emailPlaceholder')}
                  />
                </div>
              </div>

              <div>
                <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'contact.form.subjectLabel')}</label>
                <select
                  id="subject"
                  name="subject"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                >
                  <option value="">{t(locale, 'contact.form.subjectPlaceholder')}</option>
                  <option value="general">{t(locale, 'contact.form.subjectGeneral')}</option>
                  <option value="support">{t(locale, 'contact.form.subjectSupport')}</option>
                  <option value="feedback">{t(locale, 'contact.form.subjectFeedback')}</option>
                  <option value="partnership">{t(locale, 'contact.form.subjectPartnership')}</option>
                  <option value="press">{t(locale, 'contact.form.subjectPress')}</option>
                  <option value="other">{t(locale, 'contact.form.subjectOther')}</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-1">{t(locale, 'contact.form.messageLabel')}</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors resize-none"
                  placeholder={t(locale, 'contact.form.messagePlaceholder')}
                ></textarea>
              </div>

              <button
                type="submit"
                class="btn-primary w-full sm:w-auto"
              >
                {t(locale, 'contact.form.submit')}
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
              </button>
            </form>

            <!-- Success message (hidden by default) -->
            <div id="success-message" class="hidden mt-6 p-4 rounded-xl bg-green-50 border border-green-200">
              <div class="flex items-center gap-3">
                <svg class="w-6 h-6 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <p class="font-semibold text-green-800">{t(locale, 'contact.form.successTitle')}</p>
                  <p class="text-sm text-green-600">{t(locale, 'contact.form.successText')}</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Info -->
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h3 class="text-lg font-display font-bold text-gray-900 mb-4">{t(locale, 'contact.info.otherWays')}</h3>
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-900">{t(locale, 'contact.info.emailLabel')}</p>
                  <a href="mailto:hello@merrilyplan.com" class="text-primary-600 hover:text-primary-700">
                    hello@merrilyplan.com
                  </a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-900">{t(locale, 'contact.info.inAppFeedback')}</p>
                  <p class="text-gray-500 text-sm">
                    {t(locale, 'contact.info.inAppFeedbackDesc')}
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-900">{t(locale, 'contact.info.responseTime')}</p>
                  <p class="text-gray-500 text-sm">
                    {t(locale, 'contact.info.responseTimeDesc')}
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- FAQ shortcut -->
          <div class="bg-primary-50 rounded-xl p-6">
            <h3 class="font-display font-bold text-gray-900 mb-2">{t(locale, 'contact.info.lookingForAnswers')}</h3>
            <p class="text-sm text-gray-600 mb-4">
              {t(locale, 'contact.info.lookingForAnswersDesc')}
            </p>
            <a href={localePath(locale, '/pricing#faq')} class="text-primary-600 font-medium text-sm hover:text-primary-700">
              {t(locale, 'contact.info.viewFaq')} &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('success-message');

  // Read translated strings from data attributes
  const sendingText = form?.dataset.sending || 'Sending...';
  const submitText = form?.dataset.submit || 'Send Message';
  const errorAlertText = form?.dataset.errorAlert || 'Something went wrong. Please try again or email us directly at hello@merrilyplan.com';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.innerHTML = `
        <svg class="w-5 h-5 animate-spin mr-2" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        ${sendingText}
      `;
    }

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        form.style.display = 'none';
        if (successMsg) {
          successMsg.classList.remove('hidden');
        }
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = `
          ${submitText}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
        `;
      }
      alert(errorAlertText);
    }
  });
</script>
