---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils/url';

const checklistFaqs = [
  {
    q: 'When should I start planning my wedding?',
    a: 'Ideally 12-18 months before your wedding date. This gives you enough time for venue booking, vendor selection, and all the details. However, weddings can be successfully planned in as little as 3-6 months.',
  },
  {
    q: 'What is the first thing to do when planning a wedding?',
    a: 'Set your budget and determine your priorities as a couple. Everything else -- venue, guest list, vendors -- flows from your budget. Merrily Plan helps you do this with dedicated Budget and Priorities tabs.',
  },
  {
    q: 'How much does the average wedding cost?',
    a: 'The average U.S. wedding costs around $35,000-$40,000 (2025), but this varies enormously by region. Urban weddings typically cost 40-60% more than rural ones. Use our Budget Tracker to stay on top of spending.',
  },
  {
    q: 'Can I plan a wedding in 3 months?',
    a: 'Yes! Focus on securing a venue, officiant, and photographer first. Skip custom details that need long lead times (custom invitations, custom dress). Merrily Plan prioritized task list helps you focus on what matters most with short timelines.',
  },
  {
    q: 'Do I need a wedding planner?',
    a: 'Not necessarily. A digital tool like Merrily Plan gives you 32+ planning tabs covering everything a professional planner would handle. For complex or large weddings, a professional planner combined with Merrily Plan is an excellent combination.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: checklistFaqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
    },
  })),
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Free Wedding Checklist 2025-2026 - Merrily Plan',
  description: 'Complete month-by-month wedding planning checklist with 32+ free tools. From engagement to honeymoon, never miss a detail.',
  url: 'https://merrilyplan.com/wedding-checklist',
};

const timeline = [
  {
    period: '12+ Months Before',
    tasks: [
      'Set your wedding budget',
      'Determine your priorities as a couple',
      'Choose a wedding date (or 2-3 options)',
      'Start your guest list draft',
      'Research and book your venue',
      'Book your wedding planner (if using one)',
      'Start researching vendors',
    ],
  },
  {
    period: '9-11 Months Before',
    tasks: [
      'Book photographer and videographer',
      'Book caterer or finalize venue catering',
      'Choose your wedding party',
      'Start dress/attire shopping',
      'Book officiant',
      'Research florists and decorators',
      'Plan engagement party',
    ],
  },
  {
    period: '6-8 Months Before',
    tasks: [
      'Book florist, DJ/band, and other vendors',
      'Order invitations and stationery',
      'Plan ceremony details',
      'Book honeymoon travel',
      'Start wedding registry',
      'Plan rehearsal dinner',
      'Schedule dress fittings',
    ],
  },
  {
    period: '3-5 Months Before',
    tasks: [
      'Send wedding invitations',
      'Finalize menu and tasting',
      'Order wedding cake',
      'Book transportation',
      'Purchase wedding rings',
      'Plan seating arrangements',
      'Apply for marriage license',
    ],
  },
  {
    period: '1-2 Months Before',
    tasks: [
      'Confirm all vendor details',
      'Final dress fitting',
      'Create day-of timeline',
      'Prepare wedding favors',
      'Break in wedding shoes',
      'Finalize seating chart',
      'Write vows',
    ],
  },
  {
    period: 'Final Week',
    tasks: [
      'Confirm final guest count with vendors',
      'Pack for honeymoon',
      'Prepare emergency kit',
      'Rehearsal and rehearsal dinner',
      'Delegate day-of responsibilities',
      'Relax and enjoy the moment',
    ],
  },
];
---

<BaseLayout
  title="Free Wedding Checklist 2025-2026"
  description="Complete month-by-month wedding planning checklist with 32+ free tools. Track every task from engagement to honeymoon with Merrily Plan."
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-primary-50 via-white to-accent-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary-100 text-primary-700 text-sm font-medium mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
        Free Wedding Planning Tool
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-gray-900 leading-tight mb-6">
        Your Complete
        <span class="gradient-text"> Wedding Checklist</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto mb-10">
        A month-by-month wedding planning timeline with every task you need. Track your progress with Merrily Plan's free Task Tracker -- no account required.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://app.merrilyplan.com" class="btn-primary text-lg px-10 py-4">
          Start Your Checklist Free
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href="#timeline" class="btn-secondary text-lg px-10 py-4">
          View Timeline
        </a>
      </div>
    </div>
  </section>

  <!-- Why Use a Checklist -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="section-heading mb-4">
          Why You Need a
          <span class="gradient-text"> Wedding Checklist</span>
        </h2>
        <p class="section-subheading">
          The average wedding involves 100+ tasks across 10+ months. A structured checklist keeps you organized and stress-free.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card text-center">
          <div class="w-14 h-14 rounded-xl bg-green-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-lg font-display font-bold text-gray-900 mb-2">Never Miss a Task</h3>
          <p class="text-gray-600">From booking vendors to writing thank-you notes, every task is accounted for and trackable.</p>
        </div>
        <div class="card text-center">
          <div class="w-14 h-14 rounded-xl bg-blue-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-display font-bold text-gray-900 mb-2">Stay on Schedule</h3>
          <p class="text-gray-600">Month-by-month breakdown ensures you tackle tasks at the right time without last-minute panic.</p>
        </div>
        <div class="card text-center">
          <div class="w-14 h-14 rounded-xl bg-purple-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-display font-bold text-gray-900 mb-2">Collaborate Easily</h3>
          <p class="text-gray-600">Share your checklist with your partner, family, or planner so everyone knows what needs doing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline Section -->
  <section id="timeline" class="py-16 md:py-24 bg-gradient-to-br from-gray-50 to-primary-50/30">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">
          Month-by-Month
          <span class="gradient-text"> Wedding Timeline</span>
        </h2>
        <p class="section-subheading">
          Follow this proven timeline to stay on track from engagement to "I do."
        </p>
      </div>

      <div class="space-y-8">
        {timeline.map(({ period, tasks }, groupIndex) => (
          <div class="relative">
            <div class="flex items-start gap-6">
              <!-- Timeline dot and line -->
              <div class="flex flex-col items-center flex-shrink-0">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center text-white font-bold text-sm">
                  {groupIndex + 1}
                </div>
                {groupIndex < timeline.length - 1 && (
                  <div class="w-0.5 h-full bg-primary-200 mt-2"></div>
                )}
              </div>

              <!-- Content -->
              <div class="flex-1 pb-8">
                <h3 class="text-xl font-display font-bold text-gray-900 mb-4">{period}</h3>
                <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                  <ul class="space-y-3">
                    {tasks.map((task) => (
                      <li class="flex items-start gap-3">
                        <div class="w-5 h-5 mt-0.5 rounded border-2 border-primary-300 flex-shrink-0"></div>
                        <span class="text-gray-700">{task}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Merrily Plan Features for Checklist -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="section-heading mb-4">
          Why Track Your Checklist with
          <span class="gradient-text"> Merrily Plan</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="card text-center">
          <div class="w-12 h-12 rounded-xl bg-primary-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-gray-900 mb-2">Task Tracker</h3>
          <p class="text-sm text-gray-600">Built-in task management with due dates and progress tracking</p>
        </div>
        <div class="card text-center">
          <div class="w-12 h-12 rounded-xl bg-primary-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-gray-900 mb-2">Smart Calendar</h3>
          <p class="text-sm text-gray-600">Visual calendar with all deadlines and appointments in one view</p>
        </div>
        <div class="card text-center">
          <div class="w-12 h-12 rounded-xl bg-primary-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-gray-900 mb-2">Budget Tracker</h3>
          <p class="text-sm text-gray-600">Track every expense against your budget in real time</p>
        </div>
        <div class="card text-center">
          <div class="w-12 h-12 rounded-xl bg-primary-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-gray-900 mb-2">Share & Collaborate</h3>
          <p class="text-sm text-gray-600">Share tasks with your partner or wedding planner</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="section-heading mb-4">
          Wedding Checklist
          <span class="gradient-text"> FAQs</span>
        </h2>
      </div>

      <div class="space-y-4">
        {checklistFaqs.map(({ q, a }) => (
          <details class="group bg-white rounded-xl p-6 shadow-sm border border-gray-100 cursor-pointer">
            <summary class="flex items-center justify-between font-semibold text-gray-900 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-gray-600 leading-relaxed">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-20 bg-gradient-to-br from-primary-600 to-accent-600 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">
        Start Checking Off Your Wedding To-Dos
      </h2>
      <p class="text-lg text-white/80 mb-8">
        Open Merrily Plan and start tracking your wedding checklist for free. No account needed, works offline, available on all platforms.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://app.merrilyplan.com"
          class="inline-flex items-center px-10 py-4 rounded-full bg-white text-primary-700 font-semibold text-lg hover:bg-gray-100 transition-all duration-200 shadow-xl"
        >
          Open Merrily Plan Free
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href={url('/blog/wedding-checklist-2025')}
          class="inline-flex items-center px-10 py-4 rounded-full border-2 border-white/50 text-white font-semibold text-lg hover:bg-white/10 transition-all duration-200"
        >
          Read Full Guide
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
