---
import BaseLayout from '../layouts/BaseLayout.astro';

const aiFaqs = [
  {
    q: 'How does AI wedding planning work?',
    a: 'Merrily Plan uses AI to analyze your wedding details -- budget, guest count, location, priorities -- and generates smart suggestions for budget allocation, timeline tasks, vendor questions, and more. You always remain in control and can accept, modify, or ignore any suggestion.',
  },
  {
    q: 'Is AI wedding planning safe? Will my data be shared?',
    a: 'Your privacy is our priority. AI suggestions are generated based on your inputs, and we never sell your data to third parties. On the Free plan, your data never even leaves your device. On Pro, data is encrypted in transit and at rest.',
  },
  {
    q: 'Can AI replace a human wedding planner?',
    a: 'AI is a powerful assistant, not a replacement. It excels at data-driven tasks like budget optimization, timeline generation, and vendor comparison. For creative decisions, venue visits, and day-of coordination, a human planner adds irreplaceable value. Many professional planners use Merrily Plan alongside their expertise.',
  },
  {
    q: 'What AI features are included in the Free plan?',
    a: 'The Free plan includes all 32 planning tools and basic organizational features. Advanced AI-powered suggestions (smart budget allocation, AI-generated timelines, intelligent vendor questions) are available in the Pro plan at $9/month.',
  },
  {
    q: 'How accurate are AI budget suggestions?',
    a: 'AI budget suggestions are based on real wedding cost data and regional averages. They provide a strong starting point that you should adjust based on your specific vendors and preferences. The AI learns from your inputs and refines suggestions as you add more details.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: aiFaqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
    },
  })),
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'AI Wedding Planner - Smart Wedding Planning with AI | Merrily Plan',
  description: 'Plan your wedding with AI-powered tools. Smart budget suggestions, automated timelines, intelligent vendor questions, and more.',
  url: 'https://merrilyplan.com/ai-wedding-planner',
};

const aiFeatures = [
  {
    title: 'Smart Budget Allocation',
    description: 'AI analyzes your total budget, guest count, and location to suggest optimal spending across categories like venue, catering, photography, and decor.',
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Automated Timeline Generation',
    description: 'Enter your wedding date and AI creates a personalized month-by-month task list with deadlines, prioritized based on your specific wedding plans.',
    icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  },
  {
    title: 'Intelligent Vendor Questions',
    description: 'AI generates tailored questions for each vendor type -- photographers, caterers, florists, DJs -- so you never forget to ask important contract details.',
    icon: 'M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Seating Optimization',
    description: 'AI helps arrange seating by analyzing guest relationships, avoiding conflicts, grouping families, and balancing table sizes for harmonious reception seating.',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
  },
  {
    title: 'Day-of Timeline Builder',
    description: 'AI generates a detailed hour-by-hour wedding day schedule including prep, ceremony, photos, reception, and transitions with realistic time buffers.',
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Content Suggestions',
    description: 'Get AI-generated ideas for vows, toasts, wedding website text, invitation wording, and thank-you notes tailored to your style and relationship.',
    icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
  },
];
---

<BaseLayout
  title="AI Wedding Planner - Smart Wedding Planning with AI"
  description="Plan your wedding with AI-powered tools. Smart budget suggestions, automated timelines, intelligent vendor questions, and seating optimization. Free to start."
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="relative overflow-hidden py-16 md:py-24 bg-gradient-to-br from-primary-50 via-white to-accent-50">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-80 h-80 rounded-full bg-primary-200/20 blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-80 h-80 rounded-full bg-accent-200/20 blur-3xl"></div>
    </div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary-100 text-primary-700 text-sm font-medium mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
        </svg>
        AI-Powered Wedding Planning
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-gray-900 leading-tight mb-6">
        Plan Your Wedding with
        <span class="gradient-text"> Artificial Intelligence</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto mb-10">
        Let AI handle the complexity of wedding planning. Smart budget allocation, automated timelines, intelligent vendor questions -- all while you stay in control.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://app.merrilyplan.com" class="btn-primary text-lg px-10 py-4">
          Try AI Planning Free
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href="#features" class="btn-secondary text-lg px-10 py-4">
          See AI Features
        </a>
      </div>
    </div>
  </section>

  <!-- How AI Wedding Planning Works -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">
          How AI Wedding Planning
          <span class="gradient-text"> Works</span>
        </h2>
        <p class="section-subheading">
          Three simple steps to smarter wedding planning.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center mx-auto mb-6 text-2xl font-display font-bold">
            1
          </div>
          <h3 class="text-xl font-display font-bold text-gray-900 mb-3">Enter Your Details</h3>
          <p class="text-gray-600">
            Tell us your wedding date, budget, guest count, location, and priorities. The more details you provide, the smarter the suggestions.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center mx-auto mb-6 text-2xl font-display font-bold">
            2
          </div>
          <h3 class="text-xl font-display font-bold text-gray-900 mb-3">Get AI Suggestions</h3>
          <p class="text-gray-600">
            AI analyzes your inputs against real wedding data and generates personalized recommendations for budgets, timelines, vendors, and more.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center mx-auto mb-6 text-2xl font-display font-bold">
            3
          </div>
          <h3 class="text-xl font-display font-bold text-gray-900 mb-3">Refine & Execute</h3>
          <p class="text-gray-600">
            Review suggestions, customize them to your taste, and use Merrily Plan's 32+ tools to execute your plan. AI adapts as your plans evolve.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- AI Features Grid -->
  <section id="features" class="py-16 md:py-24 bg-gradient-to-br from-gray-50 to-primary-50/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="section-heading mb-4">
          AI-Powered
          <span class="gradient-text"> Planning Features</span>
        </h2>
        <p class="section-subheading">
          Intelligent tools that make wedding planning faster, smarter, and less stressful.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {aiFeatures.map(({ title, description, icon }) => (
          <div class="card group">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
              </svg>
            </div>
            <h3 class="text-xl font-display font-bold text-gray-900 mb-2">{title}</h3>
            <p class="text-gray-600 leading-relaxed">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AI + Human Approach -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="section-heading mb-6">
            AI Assists,
            <span class="gradient-text"> You Decide</span>
          </h2>
          <p class="text-gray-600 mb-6 leading-relaxed">
            We believe AI should enhance your planning experience, not replace your personal touch. Every suggestion is just that -- a suggestion. You always have full control over your wedding decisions.
          </p>
          <ul class="space-y-4">
            {[
              'AI suggestions are clearly labeled and always optional',
              'Your data privacy is protected -- we never sell your information',
              'Human creativity + AI efficiency = the perfect combination',
              'Works alongside professional wedding planners, not against them',
            ].map((item) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-gradient-to-br from-primary-50 to-accent-50 rounded-2xl p-8 md:p-10">
          <div class="space-y-6">
            <div class="bg-white rounded-xl p-4 shadow-sm">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                </svg>
                <span class="text-sm font-semibold text-primary-700">AI Suggestion</span>
              </div>
              <p class="text-sm text-gray-700">Based on your $30,000 budget and 120 guests, I recommend allocating 45% to venue and catering, 12% to photography...</p>
            </div>
            <div class="bg-white rounded-xl p-4 shadow-sm">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm font-semibold text-green-700">Your Decision</span>
              </div>
              <p class="text-sm text-gray-700">Looks good! I will increase the photography budget to 15% since photos are our top priority.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-16 md:py-20 bg-gradient-to-br from-primary-50 to-accent-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <blockquote class="text-xl md:text-2xl font-display text-gray-800 leading-relaxed mb-6">
        "The AI budget suggestions saved us hours of research. It knew the average costs for our area and helped us allocate our budget realistically."
      </blockquote>
      <div>
        <div class="font-semibold text-gray-900">Emily & Jordan</div>
        <div class="text-sm text-gray-500">Married August 2025, San Francisco</div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="section-heading mb-4">
          AI Wedding Planning
          <span class="gradient-text"> FAQs</span>
        </h2>
      </div>

      <div class="space-y-4">
        {aiFaqs.map(({ q, a }) => (
          <details class="group bg-white rounded-xl p-6 shadow-sm border border-gray-100 cursor-pointer">
            <summary class="flex items-center justify-between font-semibold text-gray-900 list-none">
              {q}
              <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-gray-600 leading-relaxed">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-20 bg-gradient-to-br from-primary-600 to-accent-600 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">
        Experience AI-Powered Wedding Planning
      </h2>
      <p class="text-lg text-white/80 mb-8">
        Join thousands of couples using AI to plan smarter, faster, and stress-free. Start with the free plan -- no account needed.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://app.merrilyplan.com"
          class="inline-flex items-center px-10 py-4 rounded-full bg-white text-primary-700 font-semibold text-lg hover:bg-gray-100 transition-all duration-200 shadow-xl"
        >
          Start Planning with AI
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center px-10 py-4 rounded-full border-2 border-white/50 text-white font-semibold text-lg hover:bg-white/10 transition-all duration-200"
        >
          Compare Plans
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
